# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=fullstack_db

# JWT — generate a strong random secret, e.g.: openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_secret

# Server
PORT=3000

# Current football season year (e.g. 2025 for the 2025/26 season)
CURRENT_SEASON=2025

# Frontend origin (used for CORS)
FRONTEND_URL=http://localhost:5173

# football-data.org API key — get a free key at https://www.football-data.org/
FOOTBALL_DATA_API_KEY=your_api_key_here
